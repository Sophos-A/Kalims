# ===== General Settings =====
SECRET_KEY=your-strong-secret-key-here  # Used for JWT/session security
ENVIRONMENT=development                 # Options: development, production
LOG_LEVEL=INFO                         # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=app_logs.log                  # Log file path

# ===== Triage Parameters =====
TRIAGE_THRESHOLD=0.7                   # Severity score threshold (0.0-1.0)
MAX_SYMPTOM_COUNT=10                   # Max symptoms per patient record

# Vital sign thresholds (sys=mmHg, dia=mmHg, hr=bpm, o2_sat=%, temp=°C)
BP_SYS_HIGH=180                        # Systolic hypertension threshold
BP_SYS_LOW=90                          # Systolic hypotension threshold
BP_DIA_HIGH=120                        # Diastolic hypertension threshold
BP_DIA_LOW=50                          # Diastolic hypotension threshold
HR_HIGH=140                            # Tachycardia threshold
HR_LOW=40                              # Bradycardia threshold
O2_SAT_LOW=90                          # Hypoxia threshold (no upper limit)
TEMP_HIGH=39.0                         # Hyperthermia threshold
TEMP_LOW=35.0                          # Hypothermia threshold

# ===== External Services =====
EMAIL_SERVICE_URL=https://your-email-api.com/send
EMAIL_API_KEY=your_email_service_api_key
ALERT_SERVICE_URL=https://your-alert-api.com/notify
ALERT_API_KEY=sk-OTlRRKr7vXcv-UEXK59KaA
OPENAI_API_KEY=sk-OTlRRKr7vXcv-UEXK59KaA # For AI symptom analysis

# ===== Database & Queue =====
DATABASE_URL=sqlite:///neuro_triage.db  # PostgreSQL: postgresql://user:pass@localhost/dbname
MAX_QUEUE_SIZE=100                     # Max patients in triage queue
DEFAULT_WAIT_TIME=240                  # Default wait (minutes) for low-priority cases